# Don't re-verify deps before every `pnpm run` script. On machines with a
# hardened pnpm policy (blocked build scripts / minimumReleaseAge), the verify
# step exits non-zero and blocks `pnpm dev`/`pnpm test` even though the app runs
# fine (esbuild/next/tailwind ship prebuilt platform binaries — their postinstall
# build scripts are optional). This only disables the pre-run check; it does NOT
# weaken the global build-script allowlist policy.
verify-deps-before-run=false
